{
  "pageMeta": {
    "title": "订单管理",
    "description": "管理所有订单信息，包括订单状态、金额、创建时间等"
  },
  "searchConfig": [
    {
      "key": "orderId",
      "label": "运单管理",
      "type": "input",
      "placeholder": "请输入运单编号"
    },
    {
      "key": "customerName",
      "label": "客户名称",
      "type": "input",
      "placeholder": "请输入客户名称"
    },
    {
      "key": "status",
      "label": "订单状态",
      "type": "select",
      "placeholder": "请选择订单状态",
      "options": [
        { "label": "待支付", "value": "pending" },
        { "label": "已支付", "value": "paid" },
        { "label": "已发货", "value": "shipped" },
        { "label": "已完成", "value": "completed" },
        { "label": "已取消", "value": "cancelled" }
      ]
    },
    {
      "key": "createTime",
      "label": "创建时间",
      "type": "dateRange",
      "placeholder": "开始时间,结束时间"
    }
  ],
  "tableConfig": {
    "rowKey": "id",
    "columns": [
      {
        "key": "id",
        "title": "订单编号",
        "type": "text",
        "width": 120,
        "fixed": "left"
      },
      {
        "key": "customerName",
        "title": "客户名称",
        "type": "text",
        "width": 150
      },
      {
        "key": "customerPhone",
        "title": "客户电话",
        "type": "text",
        "width": 150
      },
      {
        "key": "amount",
        "title": "订单金额",
        "type": "currency",
        "width": 120,
        "align": "right"
      },
      {
        "key": "status",
        "title": "订单状态",
        "type": "tag",
        "width": 100,
        "align": "center",
        "dictKey": "statusDict"
      },
      {
        "key": "paymentMethod",
        "title": "支付方式",
        "type": "tag",
        "width": 100,
        "align": "center",
        "dictKey": "paymentMethodDict"
      },
      {
        "key": "createTime",
        "title": "创建时间",
        "type": "datetime",
        "width": 180
      },
      {
        "key": "actions",
        "title": "操作",
        "type": "actions",
        "width": 150,
        "fixed": "right",
        "align": "center"
      }
    ],
    "dicts": {
      "statusDict": {
        "pending": { "label": "待支付", "color": "orange", "variant": "filled" },
        "paid": { "label": "已支付", "color": "green", "variant": "filled" },
        "shipped": { "label": "已发货", "color": "blue", "variant": "filled" },
        "completed": { "label": "已完成", "color": "purple", "variant": "filled" },
        "cancelled": { "label": "已取消", "color": "red", "variant": "filled" }
      },
      "paymentMethodDict": {
        "alipay": { "label": "支付宝", "color": "blue", "variant": "filled" },
        "wechat": { "label": "微信", "color": "green", "variant": "filled" },
        "card": { "label": "银行卡", "color": "purple", "variant": "filled" }
      }
    }
  },
