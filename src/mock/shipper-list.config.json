{
  "pageMeta": {
    "title": "托运企业列表",
    "description": "管理所有托运企业信息，包括企业基本信息、联系人、账号状态等"
  },
  "searchConfig": [
    {
      "key": "companyName",
      "label": "企业名称",
      "type": "input",
      "placeholder": "请输入企业名称，支持模糊搜索"
    },
    {
      "key": "creditCode",
      "label": "统一社会信用代码",
      "type": "input",
      "placeholder": "请输入18位统一社会信用代码"
    },
    {
      "key": "contactPhone",
      "label": "联系人手机号",
      "type": "input",
      "placeholder": "请输入11位手机号"
    },
    {
      "key": "accountStatus",
      "label": "账号状态",
      "type": "select",
      "placeholder": "请选择账号状态",
      "options": [
        { "label": "全部", "value": "all" },
        { "label": "启用", "value": "enabled" },
        { "label": "禁用", "value": "disabled" }
      ]
    }
  ],
  "tableConfig": {
    "rowKey": "id",
    "columns": [
      {
        "key": "companyName",
        "title": "企业名称",
        "type": "text",
        "width": 200,
        "ellipsis": true
      },
      {
        "key": "creditCode",
        "title": "统一社会信用代码",
        "type": "text",
        "width": 180
      },
      {
        "key": "contactName",
        "title": "联系人姓名",
        "type": "text",
        "width": 120
      },
      {
        "key": "contactPhone",
        "title": "联系人手机号",
        "type": "text",
        "width": 140
      },
      {
        "key": "accountStatus",
        "title": "账号状态",
        "type": "tag",
        "width": 100,
        "align": "center",
        "dictKey": "accountStatusDict"
      },
      {
        "key": "createTime",
        "title": "创建时间",
        "type": "datetime",
        "width": 180
      },
      {
        "key": "actions",
        "title": "操作",
        "type": "actions",
        "width": 280,
        "fixed": "right",
        "align": "center"
      }
    ],
    "dicts": {
      "accountStatusDict": {
        "enabled": { "label": "启用", "color": "green", "variant": "filled" },
        "disabled": { "label": "禁用", "color": "red", "variant": "filled" }
      }
    }
  },
