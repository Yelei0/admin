{
  "pageMeta": {
    "title": "产品管理",
    "description": "管理所有产品信息，包括产品名称、价格、库存、状态等"
  },
  "searchConfig": [
    {
      "key": "name",
      "label": "产品名称",
      "type": "input",
      "placeholder": "请输入产品名称"
    },
    {
      "key": "category",
      "label": "产品分类",
      "type": "select",
      "placeholder": "请选择产品分类",
      "options": [
        { "label": "电子产品", "value": "electronics" },
        { "label": "服装", "value": "clothing" },
        { "label": "食品", "value": "food" },
        { "label": "图书", "value": "books" }
      ]
    },
    {
      "key": "status",
      "label": "产品状态",
      "type": "select",
      "placeholder": "请选择产品状态",
      "options": [
        { "label": "在售", "value": "active" },
        { "label": "下架", "value": "inactive" }
      ]
    }
  ],
  "tableConfig": {
    "rowKey": "id",
    "columns": [
      {
        "key": "id",
        "title": "产品ID",
        "type": "text",
        "width": 100,
        "fixed": "left"
      },
      {
        "key": "name",
        "title": "产品名称",
        "type": "text",
        "width": 200
      },
      {
        "key": "category",
        "title": "分类",
        "type": "tag",
        "width": 120,
        "align": "center",
        "dictKey": "categoryDict"
      },
      {
        "key": "price",
        "title": "价格",
        "type": "currency",
        "width": 120,
        "align": "right"
      },
      {
        "key": "stock",
        "title": "库存",
        "type": "text",
        "width": 100,
        "align": "center"
      },
      {
        "key": "status",
        "title": "状态",
        "type": "tag",
        "width": 100,
        "align": "center",
        "dictKey": "statusDict"
      },
      {
        "key": "createTime",
        "title": "创建时间",
        "type": "datetime",
        "width": 180
      },
      {
        "key": "actions",
        "title": "操作",
        "type": "actions",
        "width": 150,
        "fixed": "right",
        "align": "center"
      }
    ],
    "dicts": {
      "categoryDict": {
        "electronics": { "label": "电子产品", "color": "blue" },
        "clothing": { "label": "服装", "color": "green" },
